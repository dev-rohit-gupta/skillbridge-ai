# PostgreSQL: use a Neon pooled URL at runtime and a direct URL for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@YOUR-ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require

PORT=4000
WEB_ORIGIN=http://localhost:5173

ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
REFRESH_TOKEN_SECRET=replace-with-another-at-least-32-random-characters
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Supabase is used only for private resume file storage.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_RESUME_BUCKET=resumes

# The frontend calls /api through Vite locally and a Vercel rewrite in production.
VITE_API_URL=/api/v1
VITE_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY
